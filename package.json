{
  "name": "wild-animals-adventure",
  "version": "1.0.0",
  "description": "Educational web application for kindergarten students to learn about animals",
  "main": "index.html",
  "scripts": {
    "start": "python3 -m http.server 8080",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "build": "node scripts/cache-bust.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "cache-bust": "node scripts/cache-bust.js"
  },
  "keywords": [
    "education",
    "kindergarten",
    "animals",
    "learning",
    "interactive",
    "static-website"
  ],
  "author": "TeacherEvan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TeacherEvan/Wild-animals.git"
  },
  "homepage": "https://github.com/TeacherEvan/Wild-animals",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.8"
  }
}
